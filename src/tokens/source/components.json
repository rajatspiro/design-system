    "radius":      { "$value": "{radius.full}",       "$type": "borderRadius" },
    "font-family": { "$value": "{font-family.sans}",  "$type": "fontFamilies" },
    "font-weight": { "$value": "{font-weight.medium}","$type": "fontWeights" },
    "icon-gap":    { "$value": "{space.1}",           "$type": "spacing" },
    "padding-inline": {
