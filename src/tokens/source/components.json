    "radius":     { "$value": "{radius.full}",        "$type": "borderRadius" },
    "height": {
      "xs": { "$value": "4px",  "$type": "sizing" },
      "sm": { "$value": "6px",  "$type": "sizing" },
      "md": { "$value": "8px",  "$type": "sizing" },
      "lg": { "$value": "12px", "$type": "sizing" }
