    "fill-brand":     { "$value": "{color.brand.700}",   "$type": "color" },
    "fill-success":   { "$value": "{color.success.600}", "$type": "color" },
    "fill-warning":   { "$value": "{color.warning.600}", "$type": "color" },
    "fill-danger":    { "$value": "{color.danger.600}",  "$type": "color" },
    "label-color":    { "$value": "{color.text.secondary}","$type": "color" },
    "label-size":     { "$value": "{font-size.100}",     "$type": "fontSizes" },
    "segment-gap":    { "$value": "{space.1}",           "$type": "spacing" },
    "circular-track": { "$value": "{color.neutral.200}", "$type": "color" },
