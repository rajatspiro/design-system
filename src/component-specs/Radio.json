{
  "$schema": "design-system.component.v1",
  "name": "Radio",
  "description": "Single radio input within a group.",
  "page": "Components / Radio",

  "variantProperties": {
    "state": ["default", "hover", "checked", "checked-hover", "disabled", "checked-disabled", "focus-visible"],
    "hasDescription": [false, true]
  },

  "structure": {
    "type": "frame",
    "autoLayout": {
      "direction": "horizontal",
      "padding": { "inline": 0, "block": 0 },
      "gap": "{radio/label-gap}",
      "primaryAlignment": "start",
      "counterAlignment": "start"
    },
    "size": { "width": "auto", "height": "auto" },
    "fills": [],
    "strokes": [],
    "children": [
      {
        "type": "frame",
        "name": "Indicator",
        "autoLayout": {
          "direction": "horizontal",
          "padding": { "inline": 0, "block": 0 },
          "gap": 0,
          "primaryAlignment": "center",
          "counterAlignment": "center"
        },
        "size": { "width": "{radio/size}", "height": "{radio/size}" },
        "cornerRadius": 9999,
        "fills": [{ "type": "solid", "variable": "{radio/bg}" }],
        "strokes": [{ "variable": "{radio/border}", "weight": "{border-width/1}", "position": "inside" }],
        "children": []
      },
      {
        "type": "frame",
        "name": "Text stack",
        "autoLayout": {
          "direction": "vertical",
          "padding": { "inline": 0, "block": 0 },
          "gap": 2,
          "primaryAlignment": "start",
          "counterAlignment": "start"
        },
        "size": { "width": "auto", "height": "auto" },
        "fills": [],
        "strokes": [],
        "children": [
          {
            "type": "text",
            "name": "Label",
            "content": "Radio label",
            "fills": [{ "variable": "{radio/label-color}" }],
            "fontSize": "{text/body-s/size}",
            "fontWeight": "{font-weight/regular}"
          },
          {
            "type": "text",
            "name": "Description",
            "appliesIf": "${hasDescription}",
            "content": "Optional supporting text.",
            "fills": [{ "variable": "{color/text/tertiary}" }],
            "fontSize": "{font-size/100}",
            "fontWeight": "{font-weight/regular}"
          }
        ]
      }
    ]
  },

  "variantOverrides": [
    { "when": { "state": "checked" }, "structure": {
      "children": [
        {
          "type": "frame",
          "name": "Indicator",
          "fills": [{ "type": "solid", "variable": "{radio/bg-checked}" }],
          "strokes": [{ "variable": "{radio/border-checked}", "weight": "{border-width/1}", "position": "inside" }],
          "children": [
            { "type": "frame", "name": "Dot", "size": { "width": 6, "height": 6 }, "cornerRadius": 9999, "fills": [{ "type": "solid", "variable": "{radio/dot}" }], "strokes": [] }
          ]
        }
      ]
    } },
    { "when": { "state": "checked-hover" }, "structure": {
      "children": [
        {
          "type": "frame",
          "name": "Indicator",
          "fills": [{ "type": "solid", "variable": "{radio/bg-checked}" }],
          "strokes": [{ "variable": "{radio/border-checked}", "weight": "{border-width/1}", "position": "inside" }],
          "children": [
            { "type": "frame", "name": "Dot", "size": { "width": 6, "height": 6 }, "cornerRadius": 9999, "fills": [{ "type": "solid", "variable": "{radio/dot}" }], "strokes": [] }
          ]
        }
      ]
    } },
    { "when": { "state": "disabled" }, "structure": {
      "opacity": { "appliesIf": true, "variable": "{button/disabled-opacity}" },
      "children": [
        {
          "type": "frame",
          "name": "Indicator",
          "fills": [{ "type": "solid", "variable": "{radio/bg-disabled}" }],
          "strokes": [{ "variable": "{radio/border-disabled}", "weight": "{border-width/1}", "position": "inside" }]
        }
      ]
    } },
    { "when": { "state": "checked-disabled" }, "structure": {
      "opacity": { "appliesIf": true, "variable": "{button/disabled-opacity}" },
      "children": [
        {
          "type": "frame",
          "name": "Indicator",
          "fills": [{ "type": "solid", "variable": "{radio/bg-checked}" }],
          "children": [
            { "type": "frame", "name": "Dot", "size": { "width": 6, "height": 6 }, "cornerRadius": 9999, "fills": [{ "type": "solid", "variable": "{radio/dot}" }], "strokes": [] }
          ]
        }
      ]
    } }
  ],

  "documentation": {
    "anatomy": "[ ◉ ]  Label\n        Description?",
    "do": ["Use vertical orientation by default.", "Include a description when option labels are ambiguous."],
    "dont": ["Don't use radios for two options where a default+opt-out fits — use a Checkbox/Switch."],
    "tokensConsumed": ["radio/{size,bg,bg-checked,border,border-checked,dot,bg-disabled,border-disabled,label-color,label-gap}"]
  }
}
