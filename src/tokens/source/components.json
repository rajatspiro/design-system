{
  "button": {
    "radius":         { "$value": "{radius.md}",            "$type": "borderRadius" },
    "border-width":   { "$value": "{border-width.1}",       "$type": "borderWidth" },
    "font-family":    { "$value": "{font-family.sans}",     "$type": "fontFamilies" },
    "font-weight":    { "$value": "{text.label-m.weight}",  "$type": "fontWeights" },
    "letter-spacing": { "$value": "{letter-spacing.normal}","$type": "letterSpacing" },
    "icon-gap":       { "$value": "{space.2}",              "$type": "spacing" },
    "transition":     { "$value": "background-color {duration.base} {ease.in-out}, color {duration.base} {ease.in-out}, border-color {duration.base} {ease.in-out}, box-shadow {duration.fast} {ease.out}", "$type": "other" },
    "disabled-opacity":{ "$value": "{opacity.60}",          "$type": "opacity" },
    "focus-ring":     { "$value": "0 0 0 2px {color.surface.default}, 0 0 0 4px {color.border.focus}", "$type": "other" },

    "height": {
      "xs": { "$value": "24px", "$type": "sizing" },
      "sm": { "$value": "32px", "$type": "sizing" },
      "md": { "$value": "40px", "$type": "sizing" },
      "lg": { "$value": "48px", "$type": "sizing" },
      "xl": { "$value": "56px", "$type": "sizing" }
    },
    "padding-inline": {
      "xs": { "$value": "{space.2}", "$type": "spacing" },
      "sm": { "$value": "{space.3}", "$type": "spacing" },
      "md": { "$value": "{space.4}", "$type": "spacing" },
      "lg": { "$value": "{space.5}", "$type": "spacing" },
      "xl": { "$value": "{space.6}", "$type": "spacing" }
    },
    "font-size": {
      "xs": { "$value": "{font-size.100}", "$type": "fontSizes" },
      "sm": { "$value": "{font-size.200}", "$type": "fontSizes" },
      "md": { "$value": "{font-size.200}", "$type": "fontSizes" },
      "lg": { "$value": "{font-size.300}", "$type": "fontSizes" },
      "xl": { "$value": "{font-size.400}", "$type": "fontSizes" }
    },

    "primary": {
      "bg":          { "$value": "{color.action.primary.bg}",          "$type": "color" },
      "bg-hover":    { "$value": "{color.action.primary.bg-hover}",    "$type": "color" },
      "bg-active":   { "$value": "{color.action.primary.bg-active}",   "$type": "color" },
      "bg-disabled": { "$value": "{color.action.primary.bg-disabled}", "$type": "color" },
      "fg":          { "$value": "{color.action.primary.fg}",          "$type": "color" },
      "border":      { "$value": "{color.action.primary.bg}",          "$type": "color" }
    },
    "secondary": {
      "bg":          { "$value": "{color.action.secondary.bg}",          "$type": "color" },
      "bg-hover":    { "$value": "{color.action.secondary.bg-hover}",    "$type": "color" },
      "bg-active":   { "$value": "{color.action.secondary.bg-active}",   "$type": "color" },
      "bg-disabled": { "$value": "{color.action.secondary.bg-disabled}", "$type": "color" },
      "fg":          { "$value": "{color.action.secondary.fg}",          "$type": "color" },
      "border":      { "$value": "{color.border.default}",               "$type": "color" }
    },
    "tertiary": {
      "bg":          { "$value": "{color.action.tertiary.bg}",          "$type": "color" },
      "bg-hover":    { "$value": "{color.action.tertiary.bg-hover}",    "$type": "color" },
      "bg-active":   { "$value": "{color.action.tertiary.bg-active}",   "$type": "color" },
      "bg-disabled": { "$value": "{color.action.tertiary.bg-disabled}", "$type": "color" },
      "fg":          { "$value": "{color.action.tertiary.fg}",          "$type": "color" },
      "border":      { "$value": "{color.transparent}",                 "$type": "color" }
    },
    "destructive": {
      "bg":          { "$value": "{color.action.destructive.bg}",          "$type": "color" },
      "bg-hover":    { "$value": "{color.action.destructive.bg-hover}",    "$type": "color" },
      "bg-active":   { "$value": "{color.action.destructive.bg-active}",   "$type": "color" },
      "bg-disabled": { "$value": "{color.action.destructive.bg-disabled}", "$type": "color" },
      "fg":          { "$value": "{color.action.destructive.fg}",          "$type": "color" },
      "border":      { "$value": "{color.action.destructive.bg}",          "$type": "color" }
    },
    "destructive-secondary": {
      "bg":          { "$value": "{color.transparent}",        "$type": "color" },
      "bg-hover":    { "$value": "{color.feedback.danger.bg}", "$type": "color" },
      "bg-active":   { "$value": "{color.danger.100}",         "$type": "color" },
      "bg-disabled": { "$value": "{color.transparent}",        "$type": "color" },
      "fg":          { "$value": "{color.text.danger}",        "$type": "color" },
      "border":      { "$value": "{color.border.error}",       "$type": "color" }
    },
    "link": {
      "bg":          { "$value": "{color.transparent}",   "$type": "color" },
      "bg-hover":    { "$value": "{color.transparent}",   "$type": "color" },
      "bg-active":   { "$value": "{color.transparent}",   "$type": "color" },
      "bg-disabled": { "$value": "{color.transparent}",   "$type": "color" },
      "fg":          { "$value": "{color.text.link}",     "$type": "color" },
      "fg-hover":    { "$value": "{color.text.link-hover}","$type": "color" },
      "border":      { "$value": "{color.transparent}",   "$type": "color" }
    }
  },

  "field": {
    "label": {
      "color":  { "$value": "{color.text.primary}",       "$type": "color" },
      "size":   { "$value": "{text.label-m.size}",        "$type": "fontSizes" },
      "weight": { "$value": "{text.label-m.weight}",      "$type": "fontWeights" },
      "line":   { "$value": "{text.label-m.line}",        "$type": "lineHeights" },
      "gap":    { "$value": "{space.2}",                  "$type": "spacing" }
    },
    "helper": {
      "color": { "$value": "{color.text.tertiary}",  "$type": "color" },
      "size":  { "$value": "{text.caption.size}",    "$type": "fontSizes" },
      "line":  { "$value": "{text.caption.line}",    "$type": "lineHeights" }
    },
    "error":    { "color": { "$value": "{color.text.danger}",   "$type": "color" } },
    "success":  { "color": { "$value": "{color.text.success}",  "$type": "color" } },
    "required": { "color": { "$value": "{color.text.danger}",   "$type": "color" } },
    "stack-gap": { "$value": "{space.2}", "$type": "spacing" }
  },

  "input": {
    "bg":              { "$value": "{color.surface.default}",   "$type": "color" },
    "bg-disabled":     { "$value": "{color.surface.sunken}",    "$type": "color" },
    "fg":              { "$value": "{color.text.primary}",      "$type": "color" },
    "fg-placeholder":  { "$value": "{color.text.muted}",        "$type": "color" },
    "fg-disabled":     { "$value": "{color.text.disabled}",     "$type": "color" },
    "border":          { "$value": "{color.border.default}",    "$type": "color" },
    "border-hover":    { "$value": "{color.border.strong}",     "$type": "color" },
    "border-focus":    { "$value": "{color.border.focus}",      "$type": "color" },
    "border-error":    { "$value": "{color.border.error}",      "$type": "color" },
    "border-success":  { "$value": "{color.border.success}",    "$type": "color" },
    "border-disabled": { "$value": "{color.border.disabled}",   "$type": "color" },
    "radius":          { "$value": "{radius.md}",               "$type": "borderRadius" },
    "border-width":    { "$value": "{border-width.1}",          "$type": "borderWidth" },
    "font-family":     { "$value": "{font-family.sans}",        "$type": "fontFamilies" },
    "font-size":       { "$value": "{text.body-s.size}",        "$type": "fontSizes" },
    "line-height":     { "$value": "{text.body-s.line}",        "$type": "lineHeights" },
    "transition":      { "$value": "border-color {duration.fast} {ease.out}, box-shadow {duration.fast} {ease.out}", "$type": "other" },
    "focus-ring":      { "$value": "0 0 0 3px rgba(60, 97, 221, 0.20)", "$type": "other" },
    "focus-ring-error":{ "$value": "0 0 0 3px rgba(220, 38, 38, 0.20)", "$type": "other" },
    "icon-color":      { "$value": "{color.text.tertiary}",     "$type": "color" },
    "icon-gap":        { "$value": "{space.2}",                 "$type": "spacing" },

    "height": {
      "sm": { "$value": "32px", "$type": "sizing" },
      "md": { "$value": "40px", "$type": "sizing" },
      "lg": { "$value": "48px", "$type": "sizing" }
    },
    "padding-inline": {
      "sm": { "$value": "{space.2}", "$type": "spacing" },
      "md": { "$value": "{space.3}", "$type": "spacing" },
      "lg": { "$value": "{space.4}", "$type": "spacing" }
    }
  },

  "numeric": {
    "stepper-width":     { "$value": "28px",                  "$type": "sizing" },
    "stepper-bg":        { "$value": "{color.surface.sunken}","$type": "color" },
    "stepper-bg-hover":  { "$value": "{color.neutral.200}",   "$type": "color" },
    "stepper-fg":        { "$value": "{color.text.secondary}","$type": "color" }
  },

  "textarea": {
    "min-height":    { "$value": "80px",       "$type": "sizing" },
    "padding-block": { "$value": "{space.2}",  "$type": "spacing" }
  },

  "radio": {
    "size":            { "$value": "16px",                       "$type": "sizing" },
    "border":          { "$value": "{color.border.strong}",      "$type": "color" },
    "border-checked":  { "$value": "{color.action.primary.bg}",  "$type": "color" },
    "bg":              { "$value": "{color.surface.default}",    "$type": "color" },
    "bg-checked":      { "$value": "{color.action.primary.bg}",  "$type": "color" },
    "dot":             { "$value": "{color.white}",              "$type": "color" },
    "bg-disabled":     { "$value": "{color.surface.sunken}",     "$type": "color" },
    "border-disabled": { "$value": "{color.border.disabled}",    "$type": "color" },
    "focus-ring":      { "$value": "{input.focus-ring}",         "$type": "other" },
    "label-color":     { "$value": "{color.text.primary}",       "$type": "color" },
    "label-gap":       { "$value": "{space.2}",                  "$type": "spacing" },
    "group-gap":       { "$value": "{space.3}",                  "$type": "spacing" }
  },

  "checkbox": {
    "size":            { "$value": "16px",                       "$type": "sizing" },
    "radius":          { "$value": "{radius.xs}",                "$type": "borderRadius" },
    "border":          { "$value": "{color.border.strong}",      "$type": "color" },
    "border-checked":  { "$value": "{color.action.primary.bg}",  "$type": "color" },
    "bg":              { "$value": "{color.surface.default}",    "$type": "color" },
    "bg-checked":      { "$value": "{color.action.primary.bg}",  "$type": "color" },
    "mark":            { "$value": "{color.white}",              "$type": "color" },
    "bg-disabled":     { "$value": "{color.surface.sunken}",     "$type": "color" },
    "border-disabled": { "$value": "{color.border.disabled}",    "$type": "color" },
    "focus-ring":      { "$value": "{input.focus-ring}",         "$type": "other" },
    "label-color":     { "$value": "{color.text.primary}",       "$type": "color" },
    "label-gap":       { "$value": "{space.2}",                  "$type": "spacing" },
    "group-gap":       { "$value": "{space.3}",                  "$type": "spacing" }
  },

  "toast": {
    "bg":         { "$value": "{color.surface.raised}",  "$type": "color" },
    "fg":         { "$value": "{color.text.primary}",    "$type": "color" },
    "border":     { "$value": "{color.border.subtle}",   "$type": "color" },
    "radius":     { "$value": "{radius.lg}",             "$type": "borderRadius" },
    "shadow":     { "$value": "{elevation.e3}",          "$type": "boxShadow" },
    "padding":    { "$value": "{space.3} {space.4}",     "$type": "spacing" },
    "min-width":  { "$value": "320px",                   "$type": "sizing" },
    "max-width":  { "$value": "480px",                   "$type": "sizing" },
    "gap":        { "$value": "{space.3}",               "$type": "spacing" },
    "stack-gap":  { "$value": "{space.2}",               "$type": "spacing" },
    "z":          { "$value": "{z.toast}",               "$type": "other" },

    "info-icon":     { "$value": "{color.feedback.info.icon}",    "$type": "color" },
    "success-icon":  { "$value": "{color.feedback.success.icon}", "$type": "color" },
    "warning-icon":  { "$value": "{color.feedback.warning.icon}", "$type": "color" },
    "danger-icon":   { "$value": "{color.feedback.danger.icon}",  "$type": "color" },
    "neutral-icon":  { "$value": "{color.text.tertiary}",         "$type": "color" },

    "info-accent":     { "$value": "{color.info.600}",    "$type": "color" },
    "success-accent":  { "$value": "{color.success.600}", "$type": "color" },
    "warning-accent":  { "$value": "{color.warning.600}", "$type": "color" },
    "danger-accent":   { "$value": "{color.danger.600}",  "$type": "color" },
    "neutral-accent":  { "$value": "{color.neutral.400}", "$type": "color" }
