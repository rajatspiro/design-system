{
  "$schema": "design-system.component.v1",
  "name": "Toast",
  "description": "Transient notification card.",
  "page": "Components / Toast",

  "variantProperties": {
    "tone": ["info", "success", "warning", "danger", "neutral"],
    "hasDescription": [false, true],
    "hasAction": [false, true],
    "dismissible": [false, true]
  },

  "structure": {
    "type": "frame",
    "autoLayout": {
      "direction": "horizontal",
      "padding": { "inline": "{space/4}", "block": "{space/3}" },
      "gap": "{toast/gap}",
      "primaryAlignment": "start",
      "counterAlignment": "start"
    },
    "size": { "width": 400, "height": "auto" },
    "fills": [{ "type": "solid", "variable": "{toast/bg}" }],
    "strokes": [{ "variable": "{toast/border}", "weight": "{border-width/1}", "position": "inside" }],
    "cornerRadius": "{toast/radius}",
    "children": [
      {
        "type": "frame",
        "name": "Accent",
        "autoLayout": null,
        "size": { "width": 4, "height": 40 },
        "fills": [
          { "type": "solid", "variable": "{toast/info-accent}",    "appliesIf": "${tone === 'info'}" },
          { "type": "solid", "variable": "{toast/success-accent}", "appliesIf": "${tone === 'success'}" },
          { "type": "solid", "variable": "{toast/warning-accent}", "appliesIf": "${tone === 'warning'}" },
          { "type": "solid", "variable": "{toast/danger-accent}",  "appliesIf": "${tone === 'danger'}" },
          { "type": "solid", "variable": "{toast/neutral-accent}", "appliesIf": "${tone === 'neutral'}" }
        ],
        "strokes": [],
        "cornerRadius": 2
      },
      {
        "type": "frame",
        "name": "Icon",
        "autoLayout": {
          "direction": "horizontal",
          "padding": { "inline": 0, "block": 0 },
          "gap": 0,
          "primaryAlignment": "center",
          "counterAlignment": "center"
        },
        "size": { "width": 20, "height": 20 },
        "cornerRadius": 9999,
        "fills": [
          { "type": "solid", "variable": "{toast/info-icon}",    "appliesIf": "${tone === 'info'}" },
          { "type": "solid", "variable": "{toast/success-icon}", "appliesIf": "${tone === 'success'}" },
          { "type": "solid", "variable": "{toast/warning-icon}", "appliesIf": "${tone === 'warning'}" },
          { "type": "solid", "variable": "{toast/danger-icon}",  "appliesIf": "${tone === 'danger'}" },
          { "type": "solid", "variable": "{toast/neutral-icon}", "appliesIf": "${tone === 'neutral'}" }
        ],
        "strokes": [],
        "children": []
      },
      {
        "type": "frame",
        "name": "Body",
        "autoLayout": {
          "direction": "vertical",
          "padding": { "inline": 0, "block": 0 },
          "gap": 4,
          "primaryAlignment": "start",
          "counterAlignment": "start"
        },
        "size": { "width": "auto", "height": "auto" },
        "fills": [],
        "strokes": [],
        "children": [
          { "type": "text", "name": "Title", "content": "Saved", "fills": [{ "variable": "{toast/fg}" }], "fontSize": "{text/label-m/size}", "fontWeight": "{font-weight/semibold}" },
          { "type": "text", "name": "Description", "appliesIf": "${hasDescription}", "content": "Your changes are live.", "fills": [{ "variable": "{color/text/secondary}" }], "fontSize": "{font-size/100}", "fontWeight": "{font-weight/regular}" }
        ]
      },
      {
        "type": "text",
        "name": "Action",
        "appliesIf": "${hasAction}",
        "content": "Undo",
        "fills": [{ "variable": "{color/text/link}" }],
        "fontSize": "{text/label-m/size}",
        "fontWeight": "{font-weight/medium}"
      },
      {
        "type": "text",
        "name": "Dismiss",
        "appliesIf": "${dismissible}",
        "content": "×",
        "fills": [{ "variable": "{color/text/tertiary}" }],
        "fontSize": 18,
        "fontWeight": "{font-weight/medium}"
      }
    ]
  },

  "documentation": {
    "anatomy": "[ accent | icon | title + description? | action? | × ]",
    "do": ["Provide an action for any reversible operation."],
    "dont": ["Don't use Toast for blocking confirmations — use a Dialog.", "Don't use danger tone for non-error events."],
    "tokensConsumed": ["toast/{bg,fg,border,radius,gap,info-accent,success-accent,warning-accent,danger-accent,neutral-accent,info-icon,success-icon,warning-icon,danger-icon,neutral-icon}"]
  }
}
