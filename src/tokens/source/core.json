{
  "color": {
    "neutral": {
      "50":  { "$value": "#F8F9FA", "$type": "color" },
      "100": { "$value": "#F0F2F4", "$type": "color" },
      "200": { "$value": "#E6E8EB", "$type": "color" },
      "300": { "$value": "#D7DBDF", "$type": "color" },
      "400": { "$value": "#C1C8CD", "$type": "color" },
      "500": { "$value": "#889096", "$type": "color" },
      "600": { "$value": "#697177", "$type": "color" },
      "700": { "$value": "#4D5358", "$type": "color" },
      "800": { "$value": "#2C3338", "$type": "color" },
      "900": { "$value": "#1A1F23", "$type": "color" },
      "950": { "$value": "#11181C", "$type": "color" }
    },
    "brand": {
      "50":  { "$value": "#EEF2FE", "$type": "color" },
      "100": { "$value": "#DDE6FE", "$type": "color" },
      "200": { "$value": "#ADBFF5", "$type": "color", "$description": "Existing token: button primary disabled bg" },
      "300": { "$value": "#8FA6F0", "$type": "color" },
      "400": { "$value": "#6F8AE8", "$type": "color" },
      "500": { "$value": "#5277E2", "$type": "color" },
      "600": { "$value": "#4567DD", "$type": "color" },
      "700": { "$value": "#3C61DD", "$type": "color", "$description": "Existing token: brand 700, button primary bg" },
      "800": { "$value": "#385BCC", "$type": "color", "$description": "Existing token: button primary hover" },
      "900": { "$value": "#3451B2", "$type": "color", "$description": "Existing token: button primary active" },
      "950": { "$value": "#243B8A", "$type": "color" }
    },
    "info": {
      "50":  { "$value": "#ECFEFF", "$type": "color" },
      "100": { "$value": "#CFFAFE", "$type": "color" },
      "200": { "$value": "#A5F3FC", "$type": "color" },
      "300": { "$value": "#67E8F9", "$type": "color" },
      "400": { "$value": "#22D3EE", "$type": "color" },
      "500": { "$value": "#06B6D4", "$type": "color" },
      "600": { "$value": "#0891B2", "$type": "color" },
      "700": { "$value": "#0E7490", "$type": "color" },
      "800": { "$value": "#155E75", "$type": "color" },
      "900": { "$value": "#164E63", "$type": "color" },
      "950": { "$value": "#083344", "$type": "color" }
    },
    "success": {
      "50":  { "$value": "#F0FDF4", "$type": "color" },
      "100": { "$value": "#DCFCE7", "$type": "color" },
      "200": { "$value": "#BBF7D0", "$type": "color" },
      "300": { "$value": "#86EFAC", "$type": "color" },
      "400": { "$value": "#4ADE80", "$type": "color" },
      "500": { "$value": "#22C55E", "$type": "color" },
      "600": { "$value": "#16A34A", "$type": "color" },
      "700": { "$value": "#15803D", "$type": "color" },
      "800": { "$value": "#166534", "$type": "color" },
      "900": { "$value": "#14532D", "$type": "color" },
      "950": { "$value": "#052E16", "$type": "color" }
    },
    "warning": {
      "50":  { "$value": "#FFFBEB", "$type": "color" },
      "100": { "$value": "#FEF3C7", "$type": "color" },
      "200": { "$value": "#FDE68A", "$type": "color" },
      "300": { "$value": "#FCD34D", "$type": "color" },
      "400": { "$value": "#FBBF24", "$type": "color" },
      "500": { "$value": "#F59E0B", "$type": "color" },
      "600": { "$value": "#D97706", "$type": "color" },
      "700": { "$value": "#B45309", "$type": "color" },
      "800": { "$value": "#92400E", "$type": "color" },
      "900": { "$value": "#78350F", "$type": "color" },
      "950": { "$value": "#451A03", "$type": "color" }
    },
    "danger": {
      "50":  { "$value": "#FEF2F2", "$type": "color" },
      "100": { "$value": "#FEE2E2", "$type": "color" },
      "200": { "$value": "#FECACA", "$type": "color" },
      "300": { "$value": "#FCA5A5", "$type": "color" },
      "400": { "$value": "#F87171", "$type": "color" },
      "500": { "$value": "#EF4444", "$type": "color" },
      "600": { "$value": "#DC2626", "$type": "color" },
      "700": { "$value": "#B91C1C", "$type": "color" },
      "800": { "$value": "#991B1B", "$type": "color" },
      "900": { "$value": "#7F1D1D", "$type": "color" },
      "950": { "$value": "#450A0A", "$type": "color" }
    },
    "white":       { "$value": "#FFFFFF",     "$type": "color" },
    "black":       { "$value": "#000000",     "$type": "color" },
    "transparent": { "$value": "transparent", "$type": "color" }
  },

  "space": {
    "0":  { "$value": "0",     "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension", "$description": "Existing xs" },
    "2":  { "$value": "8px",   "$type": "dimension", "$description": "Existing sm" },
    "3":  { "$value": "12px",  "$type": "dimension", "$description": "Existing md" },
    "4":  { "$value": "16px",  "$type": "dimension", "$description": "Existing lg" },
    "5":  { "$value": "20px",  "$type": "dimension", "$description": "Existing xl" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "16": { "$value": "64px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "96px",  "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },

  "font-family": {
    "sans":  { "$value": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif", "$type": "fontFamilies" },
    "serif": { "$value": "ui-serif, Georgia, \"Times New Roman\", serif", "$type": "fontFamilies" },
    "mono":  { "$value": "ui-monospace, SFMono-Regular, Menlo, Consolas, \"Liberation Mono\", monospace", "$type": "fontFamilies" }
  },

  "font-size": {
    "50":  { "$value": "11px", "$type": "fontSizes" },
    "100": { "$value": "12px", "$type": "fontSizes" },
    "200": { "$value": "14px", "$type": "fontSizes", "$description": "Existing button size" },
    "300": { "$value": "16px", "$type": "fontSizes" },
    "400": { "$value": "18px", "$type": "fontSizes" },
    "500": { "$value": "20px", "$type": "fontSizes" },
    "600": { "$value": "24px", "$type": "fontSizes" },
    "700": { "$value": "30px", "$type": "fontSizes" },
    "800": { "$value": "36px", "$type": "fontSizes" },
    "900": { "$value": "48px", "$type": "fontSizes" }
  },

  "line-height": {
    "tight":   { "$value": "1.1",   "$type": "lineHeights" },
    "snug":    { "$value": "1.25",  "$type": "lineHeights" },
    "normal":  { "$value": "1.5",   "$type": "lineHeights" },
    "relaxed": { "$value": "1.625", "$type": "lineHeights" },
    "loose":   { "$value": "2",     "$type": "lineHeights" }
  },

  "letter-spacing": {
    "tight":  { "$value": "-0.02em", "$type": "letterSpacing" },
    "normal": { "$value": "0",       "$type": "letterSpacing" },
    "wide":   { "$value": "0.04em",  "$type": "letterSpacing" },
    "wider":  { "$value": "0.08em",  "$type": "letterSpacing" }
  },

  "font-weight": {
    "regular":  { "$value": "400", "$type": "fontWeights" },
    "medium":   { "$value": "500", "$type": "fontWeights", "$description": "Existing button weight" },
    "semibold": { "$value": "600", "$type": "fontWeights" },
    "bold":     { "$value": "700", "$type": "fontWeights" }
  },

  "radius": {
    "none": { "$value": "0",      "$type": "borderRadius" },
    "xs":   { "$value": "2px",    "$type": "borderRadius" },
    "sm":   { "$value": "4px",    "$type": "borderRadius" },
    "md":   { "$value": "6px",    "$type": "borderRadius", "$description": "Existing button radius" },
    "lg":   { "$value": "8px",    "$type": "borderRadius" },
    "xl":   { "$value": "12px",   "$type": "borderRadius" },
    "2xl":  { "$value": "16px",   "$type": "borderRadius" },
    "full": { "$value": "9999px", "$type": "borderRadius" }
  },

  "border-width": {
    "0": { "$value": "0",   "$type": "borderWidth" },
    "1": { "$value": "1px", "$type": "borderWidth" },
    "2": { "$value": "2px", "$type": "borderWidth" },
    "4": { "$value": "4px", "$type": "borderWidth" }
  },

  "shadow": {
    "0": { "$value": "none", "$type": "other", "$description": "No shadow" },
    "1": {
      "$value": [
        { "x": "0", "y": "1px", "blur": "2px", "spread": "0", "color": "rgba(17, 24, 28, 0.04)", "type": "dropShadow" },
        { "x": "0", "y": "1px", "blur": "1px", "spread": "0", "color": "rgba(17, 24, 28, 0.04)", "type": "dropShadow" }
      ],
      "$type": "boxShadow"
    },
    "2": {
      "$value": [
        { "x": "0", "y": "2px", "blur": "4px", "spread": "0", "color": "rgba(17, 24, 28, 0.06)", "type": "dropShadow" },
        { "x": "0", "y": "1px", "blur": "2px", "spread": "0", "color": "rgba(17, 24, 28, 0.04)", "type": "dropShadow" }
      ],
      "$type": "boxShadow"
    },
    "3": {
      "$value": [
        { "x": "0", "y": "4px", "blur": "8px", "spread": "0", "color": "rgba(17, 24, 28, 0.08)", "type": "dropShadow" },
        { "x": "0", "y": "2px", "blur": "4px", "spread": "0", "color": "rgba(17, 24, 28, 0.04)", "type": "dropShadow" }
      ],
      "$type": "boxShadow"
    },
    "4": {
      "$value": [
        { "x": "0", "y": "8px",  "blur": "16px", "spread": "0", "color": "rgba(17, 24, 28, 0.10)", "type": "dropShadow" },
        { "x": "0", "y": "4px",  "blur": "8px",  "spread": "0", "color": "rgba(17, 24, 28, 0.06)", "type": "dropShadow" }
      ],
      "$type": "boxShadow"
    },
    "5": {
      "$value": [
        { "x": "0", "y": "16px", "blur": "32px", "spread": "0", "color": "rgba(17, 24, 28, 0.14)", "type": "dropShadow" },
        { "x": "0", "y": "8px",  "blur": "16px", "spread": "0", "color": "rgba(17, 24, 28, 0.08)", "type": "dropShadow" }
      ],
      "$type": "boxShadow"
    }
  },

  "opacity": {
    "0":   { "$value": "0",    "$type": "opacity" },
    "5":   { "$value": "0.05", "$type": "opacity" },
    "10":  { "$value": "0.1",  "$type": "opacity" },
    "20":  { "$value": "0.2",  "$type": "opacity" },
    "40":  { "$value": "0.4",  "$type": "opacity" },
    "60":  { "$value": "0.6",  "$type": "opacity" },
    "80":  { "$value": "0.8",  "$type": "opacity" },
    "100": { "$value": "1",    "$type": "opacity" }
  },

  "duration": {
    "instant": { "$value": "0ms",   "$type": "other" },
    "fast":    { "$value": "100ms", "$type": "other" },
    "base":    { "$value": "200ms", "$type": "other" },
    "slow":    { "$value": "300ms", "$type": "other" },
    "slower":  { "$value": "500ms", "$type": "other" }
  },

  "ease": {
    "linear":  { "$value": "linear",                              "$type": "other" },
    "in":      { "$value": "cubic-bezier(0.4, 0, 1, 1)",          "$type": "other" },
    "out":     { "$value": "cubic-bezier(0, 0, 0.2, 1)",          "$type": "other" },
    "in-out":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",        "$type": "other" },
    "spring":  { "$value": "cubic-bezier(0.5, 1.5, 0.5, 1)",      "$type": "other" }
  },

  "z": {
    "base":     { "$value": "0",    "$type": "other" },
    "dropdown": { "$value": "1000", "$type": "other" },
    "sticky":   { "$value": "1100", "$type": "other" },
    "overlay":  { "$value": "1200", "$type": "other" },
    "modal":    { "$value": "1300", "$type": "other" },
    "toast":    { "$value": "1400", "$type": "other" },
    "tooltip":  { "$value": "1500", "$type": "other" }
  },

  "breakpoint": {
    "sm": { "$value": "640px",  "$type": "dimension", "$description": "Small / phones in landscape" },
    "md": { "$value": "768px",  "$type": "dimension", "$description": "Medium / tablets" },
    "lg": { "$value": "1024px", "$type": "dimension", "$description": "Large / small laptops" },
    "xl": { "$value": "1280px", "$type": "dimension", "$description": "Extra large / desktops" }
  },

  "elevation": {
    "e0": { "$value": "{shadow.0}", "$type": "other" },
    "e1": { "$value": "{shadow.1}", "$type": "boxShadow" },
    "e2": { "$value": "{shadow.2}", "$type": "boxShadow" },
    "e3": { "$value": "{shadow.3}", "$type": "boxShadow" },
    "e4": { "$value": "{shadow.4}", "$type": "boxShadow" },
    "e5": { "$value": "{shadow.5}", "$type": "boxShadow" }
  },

  "text": {
    "display-l": {
      "size":   {
        "$value": "{font-size.900}",
        "$type": "fontSizes",
        "$extensions": { "design-system.css-value": "clamp(32px, 4vw + 16px, 48px)" },
        "$description": "Static value (48px) for Figma; CSS emits clamp() for fluid scaling."
      },
      "line":   { "$value": "{line-height.tight}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "display-m": {
      "size":   {
        "$value": "{font-size.800}",
        "$type": "fontSizes",
        "$extensions": { "design-system.css-value": "clamp(28px, 3vw + 16px, 36px)" }
      },
      "line":   { "$value": "{line-height.tight}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "display-s": {
      "size":   {
        "$value": "{font-size.700}",
        "$type": "fontSizes",
        "$extensions": { "design-system.css-value": "clamp(24px, 2.5vw + 12px, 30px)" }
      },
      "line":   { "$value": "{line-height.tight}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "heading-1": {
      "size":   { "$value": "{font-size.700}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "heading-2": {
      "size":   { "$value": "{font-size.600}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "heading-3": {
      "size":   { "$value": "{font-size.500}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "heading-4": {
      "size":   { "$value": "{font-size.400}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "heading-5": {
      "size":   { "$value": "{font-size.300}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "heading-6": {
      "size":   { "$value": "{font-size.200}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.semibold}","$type": "fontWeights" }
    },
    "body-l": {
      "size":   { "$value": "{font-size.400}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.normal}", "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.regular}","$type": "fontWeights" }
    },
    "body-m": {
      "size":   { "$value": "{font-size.300}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.normal}", "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.regular}","$type": "fontWeights" }
    },
    "body-s": {
      "size":   { "$value": "{font-size.200}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.normal}", "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.regular}","$type": "fontWeights" }
    },
    "label-l": {
      "size":   { "$value": "{font-size.300}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.medium}", "$type": "fontWeights" }
    },
    "label-m": {
      "size":   { "$value": "{font-size.200}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.medium}", "$type": "fontWeights" }
    },
    "label-s": {
      "size":   { "$value": "{font-size.100}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.snug}",   "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.medium}", "$type": "fontWeights" }
    },
    "caption": {
      "size":   { "$value": "{font-size.100}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.normal}", "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.regular}","$type": "fontWeights" }
    },
    "code": {
      "size":   { "$value": "{font-size.200}",      "$type": "fontSizes" },
      "line":   { "$value": "{line-height.normal}", "$type": "lineHeights" },
      "weight": { "$value": "{font-weight.regular}","$type": "fontWeights" },
      "family": { "$value": "{font-family.mono}",   "$type": "fontFamilies" }
    },
    "overline": {
      "size":    { "$value": "{font-size.50}",        "$type": "fontSizes" },
      "line":    { "$value": "{line-height.snug}",    "$type": "lineHeights" },
      "weight":  { "$value": "{font-weight.semibold}","$type": "fontWeights" },
      "spacing": { "$value": "{letter-spacing.wider}","$type": "letterSpacing" }
    }
  },

  "space-inset": {
    "sm": { "$value": "{space.2}", "$type": "spacing" },
    "md": { "$value": "{space.3}", "$type": "spacing" },
    "lg": { "$value": "{space.4}", "$type": "spacing" },
    "xl": { "$value": "{space.6}", "$type": "spacing" }
  },

  "space-stack": {
    "xs": { "$value": "{space.1}", "$type": "spacing" },
    "sm": { "$value": "{space.2}", "$type": "spacing" },
    "md": { "$value": "{space.3}", "$type": "spacing" },
    "lg": { "$value": "{space.4}", "$type": "spacing" },
    "xl": { "$value": "{space.6}", "$type": "spacing" }
  },

  "space-inline": {
    "xs": { "$value": "{space.1}", "$type": "spacing" },
    "sm": { "$value": "{space.2}", "$type": "spacing" },
    "md": { "$value": "{space.3}", "$type": "spacing" },
    "lg": { "$value": "{space.4}", "$type": "spacing" }
  }
}
