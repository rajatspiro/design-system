    "height": {
      "xs": { "$value": "18px", "$type": "sizing" },
      "sm": { "$value": "22px", "$type": "sizing" },
      "md": { "$value": "26px", "$type": "sizing" }
    },
    "font-size": {
      "xs": { "$value": "{font-size.50}",  "$type": "fontSizes" },
      "sm": { "$value": "{font-size.100}", "$type": "fontSizes" },
      "md": { "$value": "{font-size.200}", "$type": "fontSizes" }
    }
  },

  "tag": {
    "radius":           { "$value": "{radius.md}",              "$type": "borderRadius" },
    "bg-hover-tint":    { "$value": "rgba(0, 0, 0, 0.04)",      "$type": "color" },
    "remove-hover-bg":  { "$value": "rgba(0, 0, 0, 0.08)",      "$type": "color" },
    "focus-ring":       { "$value": "{input.focus-ring}",       "$type": "other" }
  },

  "tabs": {
    "gap":                  { "$value": "{space.1}",                "$type": "spacing" },
    "list-bg-segmented":    { "$value": "{color.surface.sunken}",   "$type": "color" },
    "trigger-fg":           { "$value": "{color.text.secondary}",   "$type": "color" },
    "trigger-fg-active":    { "$value": "{color.text.primary}",     "$type": "color" },
    "trigger-fg-hover":     { "$value": "{color.text.primary}",     "$type": "color" },
    "trigger-fg-disabled":  { "$value": "{color.text.disabled}",    "$type": "color" },
    "underline-color":      { "$value": "{color.action.primary.bg}","$type": "color" },
    "pill-bg-active":       { "$value": "{color.action.primary.bg}","$type": "color" },
