    "segmented-bg-active":  { "$value": "{color.surface.default}",  "$type": "color" },
    "trigger-padding": {
      "sm": { "$value": "{space.2} {space.3}", "$type": "spacing" },
      "md": { "$value": "{space.3} {space.4}", "$type": "spacing" },
      "lg": { "$value": "{space.3} {space.5}", "$type": "spacing" }
    },
    "trigger-font": {
      "sm": { "$value": "{font-size.100}", "$type": "fontSizes" },
      "md": { "$value": "{font-size.200}", "$type": "fontSizes" },
      "lg": { "$value": "{font-size.300}", "$type": "fontSizes" }
    },
    "trigger-radius":     { "$value": "{radius.md}", "$type": "borderRadius" },
    "list-radius":        { "$value": "{radius.md}", "$type": "borderRadius" },
    "trigger-transition": { "$value": "color {duration.fast} {ease.out}, background-color {duration.fast} {ease.out}", "$type": "other" }
  },

  "dropdown": {
    "bg":         { "$value": "{color.surface.raised}", "$type": "color" },
    "border":     { "$value": "{color.border.subtle}",  "$type": "color" },
    "radius":     { "$value": "{radius.md}",            "$type": "borderRadius" },
    "shadow":     { "$value": "{elevation.e3}",         "$type": "boxShadow" },
    "z":          { "$value": "{z.dropdown}",           "$type": "other" },
    "padding":    { "$value": "{space.1}",              "$type": "spacing" },
    "min-width":  { "$value": "180px",                  "$type": "sizing" },
    "max-height": { "$value": "320px",                  "$type": "sizing" },

    "item-fg":              { "$value": "{color.text.primary}",        "$type": "color" },
    "item-fg-active":       { "$value": "{color.text.primary}",        "$type": "color" },
    "item-bg-hover":        { "$value": "{color.surface.sunken}",      "$type": "color" },
    "item-bg-active":       { "$value": "{color.brand.50}",            "$type": "color" },
    "item-fg-disabled":     { "$value": "{color.text.disabled}",       "$type": "color" },
    "item-fg-destructive":  { "$value": "{color.text.danger}",         "$type": "color" },
    "item-bg-destructive-hover": { "$value": "{color.feedback.danger.bg}", "$type": "color" },
    "item-padding":         { "$value": "{space.2} {space.3}",         "$type": "spacing" },
    "item-radius":          { "$value": "{radius.sm}",                 "$type": "borderRadius" },
    "item-gap":             { "$value": "{space.2}",                   "$type": "spacing" },
    "divider-color":        { "$value": "{color.border.subtle}",       "$type": "color" },
    "shortcut-color":       { "$value": "{color.text.muted}",          "$type": "color" }
  },

  "select": {
    "trigger-bg":      { "$value": "{input.bg}",     "$type": "color" },
    "trigger-fg":      { "$value": "{input.fg}",     "$type": "color" },
    "trigger-border":  { "$value": "{input.border}", "$type": "color" },
    "trigger-radius":  { "$value": "{input.radius}", "$type": "borderRadius" },
    "trigger-padding": { "$value": "{space.2} {space.3}", "$type": "spacing" },
    "chip-bg":         { "$value": "{color.neutral.100}", "$type": "color" },
    "chip-fg":         { "$value": "{color.text.primary}","$type": "color" },
    "chip-radius":     { "$value": "{radius.sm}",         "$type": "borderRadius" },
    "chip-padding":    { "$value": "{space.1} {space.2}", "$type": "spacing" }
